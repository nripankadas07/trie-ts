{
  "name": "trie-ts",
  "version": "0.1.0",
  "description": "Type-safe Trie (prefix tree) with autocomplete, longest-prefix matching, and lexicographic iteration. Zero runtime dependencies.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "trie",
    "prefix-tree",
    "autocomplete",
    "prefix-search",
    "longest-prefix",
    "typescript"
  ],
  "author": "nripankadas07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nripankadas07/trie-ts.git"
  },
  "homepage": "https://github.com/nripankadas07/trie-ts",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
